<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/vrm_preview_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/vrm_button_toggle_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="12dp"
        android:background="#AA161220"
        android:contentDescription="@string/vrm_button_toggle_settings"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:src="@android:drawable/ic_menu_manage"
        android:tint="#FFFFFF" />

    <LinearLayout
        android:id="@+id/vrm_settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:id="@+id/vrm_settings_dismiss"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="34"
            android:clickable="true" />

        <LinearLayout
            android:id="@+id/vrm_settings_sheet"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="66"
            android:background="@drawable/vrm_sheet_background"
            android:clickable="true"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="18dp">

            <FrameLayout
                android:id="@+id/vrm_settings_handle"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:layout_marginBottom="0dp">

                <View
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="3dp"
                    android:background="@drawable/vrm_handle_bar" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/vrm_button_set_wallpaper"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_button_set_wallpaper"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/vrm_button_close_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_icon_close"
                    android:textColor="#BBBBBB"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/vrm_tabs"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/vrm_pill_container_background"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="3dp">

                <Button
                    android:id="@+id/vrm_tab_model"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_tab_model"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/vrm_tab_background"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_tab_background"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/vrm_tab_camera"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_tab_camera"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/vrm_tab_display"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_tab_display"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/vrm_tab_profile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.6"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/vrm_tab_profile"
                    android:textSize="11sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/vrm_panel_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_vrm" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/vrm_text_vrm_path"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="middle"
                                android:singleLine="true"
                                android:text="@string/vrm_no_vrm_selected"
                                android:textColor="#F2EEF8"
                                android:textSize="13sp" />

                            <Button
                                android:id="@+id/vrm_button_pick_vrm"
                                style="@style/VrmSettingsSmallButton"
                                android:text="@string/vrm_button_pick_vrm" />
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_model_transform" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <include layout="@layout/vrm_row_model_x" />
                            <include layout="@layout/vrm_row_model_y" />
                            <include layout="@layout/vrm_row_model_z" />
                            <include layout="@layout/vrm_row_model_scale" />

                            <Button
                                android:id="@+id/vrm_button_reset_model_transform"
                                style="@style/VrmSettingsWideGhostButton"
                                android:text="@string/vrm_button_reset_model_transform" />
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_interaction" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <LinearLayout
                                style="@style/VrmSettingsSwitchRow">
                                <TextView
                                    style="@style/VrmSettingsRowLabel"
                                    android:text="@string/vrm_label_touch_enabled" />
                                <Switch
                                    android:id="@+id/vrm_switch_touch_enabled"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <LinearLayout
                                style="@style/VrmSettingsSwitchRow">
                                <TextView
                                    style="@style/VrmSettingsRowLabel"
                                    android:text="@string/vrm_label_physbone_enabled" />
                                <Switch
                                    android:id="@+id/vrm_switch_physbone_enabled"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_model_info" />

                        <TextView
                            android:id="@+id/vrm_text_model_info"
                            style="@style/VrmSettingsInfoBox"
                            android:text="@string/vrm_model_info_empty" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/vrm_panel_background"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_background" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/vrm_text_background_mode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/vrm_solid_background_mode"
                                android:textColor="#F2EEF8"
                                android:textSize="13sp" />

                            <LinearLayout
                                android:id="@+id/vrm_background_mode_toggle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/vrm_pill_container_background"
                                android:orientation="horizontal"
                                android:padding="3dp">

                                <Button
                                    android:id="@+id/vrm_button_background_mode_image"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:minWidth="0dp"
                                    android:minHeight="0dp"
                                    android:text="@string/vrm_background_mode_image"
                                    android:textSize="12sp" />

                                <Button
                                    android:id="@+id/vrm_button_background_mode_solid"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:minWidth="0dp"
                                    android:minHeight="0dp"
                                    android:text="@string/vrm_background_mode_solid"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <Button
                                android:id="@+id/vrm_button_pick_image"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_marginTop="8dp"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:text="@string/vrm_button_pick_image"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/vrm_text_background_image_path"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="middle"
                                android:singleLine="true"
                                android:text="@string/vrm_no_image_selected"
                                android:textColor="#B8B1C5"
                                android:textSize="12sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_background_color" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:id="@+id/vrm_view_color_preview"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:background="#333333" />

                                <EditText
                                    android:id="@+id/vrm_edit_hex_color"
                                    android:layout_width="96dp"
                                    android:layout_height="36dp"
                                    android:layout_marginStart="10dp"
                                    android:background="#22FFFFFF"
                                    android:gravity="center"
                                    android:hint="#RRGGBB"
                                    android:inputType="textCapCharacters|textNoSuggestions"
                                    android:maxLength="7"
                                    android:singleLine="true"
                                    android:text="#333333"
                                    android:textColor="#FFFFFF"
                                    android:textColorHint="#777777"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <com.oreoreooooooo.VRM.ColorWheelView
                                android:id="@+id/vrm_color_wheel"
                                android:layout_width="match_parent"
                                android:layout_height="184dp"
                                android:layout_marginTop="12dp" />

                            <LinearLayout
                                style="@style/VrmSettingsSliderRow"
                                android:layout_marginTop="8dp">
                                <TextView
                                    style="@style/VrmSettingsSliderLabel"
                                    android:text="@string/vrm_label_color_value" />
                                <com.oreoreooooooo.VRM.ColorValueSliderView
                                    android:id="@+id/vrm_slider_color_value"
                                    android:layout_width="0dp"
                                    android:layout_height="44dp"
                                    android:layout_weight="1" />
                            </LinearLayout>

                            <include layout="@layout/vrm_row_color_r" />
                            <include layout="@layout/vrm_row_color_g" />
                            <include layout="@layout/vrm_row_color_b" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/vrm_panel_image_adjustment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/VrmSettingsSectionLabel"
                                android:text="@string/vrm_section_image_adjustment" />

                            <LinearLayout
                                style="@style/VrmSettingsCard"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="88dp"
                                        android:layout_height="wrap_content"
                                        android:text="@string/vrm_label_fit_mode"
                                        android:textColor="#CFC7DA"
                                        android:textSize="12sp" />

                                    <Spinner
                                        android:id="@+id/vrm_spinner_fit_mode"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>

                                <include layout="@layout/vrm_row_offset_x" />
                                <include layout="@layout/vrm_row_offset_y" />
                                <include layout="@layout/vrm_row_bg_scale" />

                                <Button
                                    android:id="@+id/vrm_button_reset_adjustment"
                                    style="@style/VrmSettingsWideGhostButton"
                                    android:text="@string/vrm_button_reset_adjustment" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/vrm_panel_camera"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_camera" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <include layout="@layout/vrm_row_distance" />
                            <include layout="@layout/vrm_row_height" />
                            <include layout="@layout/vrm_row_angle" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/vrm_panel_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_display" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <include layout="@layout/vrm_row_render_scale" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-4dp"
                                android:text="@string/vrm_render_scale_hint"
                                android:textColor="#77FFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_label_target_fps" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <Spinner
                                android:id="@+id/vrm_spinner_target_fps"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:spinnerMode="dropdown" />
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_performance" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <LinearLayout
                                style="@style/VrmSettingsSwitchRow">
                                <TextView
                                    style="@style/VrmSettingsRowLabel"
                                    android:text="@string/vrm_label_fps_overlay" />
                                <Switch
                                    android:id="@+id/vrm_switch_fps_overlay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/vrm_text_fps_info"
                                style="@style/VrmSettingsInfoBox"
                                android:text="@string/vrm_fps_info_empty" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="88dp"
                                    android:layout_height="wrap_content"
                                    android:text="@string/vrm_label_log_level"
                                    android:textColor="#CFC7DA"
                                    android:textSize="12sp" />

                                <Spinner
                                    android:id="@+id/vrm_spinner_log_level"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:spinnerMode="dropdown" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_troubleshooting" />

                        <LinearLayout
                            style="@style/VrmSettingsCard"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/vrm_reload_hint"
                                android:textColor="#99FFFFFF"
                                android:textSize="11sp" />

                            <Button
                                android:id="@+id/vrm_button_reload_wallpaper"
                                style="@style/VrmSettingsWideGhostButton"
                                android:text="@string/vrm_button_reload_model" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/vrm_panel_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            style="@style/VrmSettingsSectionLabel"
                            android:text="@string/vrm_section_profiles" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="@string/vrm_profile_hint"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <include layout="@layout/vrm_profile_row_1" />
                        <include layout="@layout/vrm_profile_row_2" />
                        <include layout="@layout/vrm_profile_row_3" />

                        <Button
                            android:id="@+id/vrm_button_reset_all_settings"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:background="#22FF6B6B"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:text="@string/vrm_button_reset_all_settings"
                            android:textColor="#FF8A8A"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
