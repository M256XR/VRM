<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/vrm_unity_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <Button
        android:id="@+id/vrm_button_toggle_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="12dp"
        android:background="#88333333"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="\u2699"
        android:textColor="#FFFFFF"
        android:textSize="22sp" />

    <LinearLayout
        android:id="@+id/vrm_settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:id="@+id/vrm_settings_dismiss"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="35"
            android:clickable="true" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="65"
            android:background="#E01a1a1a"
            android:clickable="true"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp"
                android:paddingEnd="16dp"
                android:paddingStart="16dp"
                android:paddingTop="12dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vrm_settings_title"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/vrm_button_close_settings"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#00000000"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="\u2715"
                        android:textColor="#AAAAAA"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- ===== VRM ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/vrm_section_vrm"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/vrm_text_vrm_path"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="middle"
                        android:singleLine="true"
                        android:text="@string/vrm_no_vrm_selected"
                        android:textColor="#CCCCCC"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/vrm_button_pick_vrm"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingEnd="12dp"
                        android:paddingStart="12dp"
                        android:text="@string/vrm_button_pick_vrm"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ===== Camera ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_camera"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_distance"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_distance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_distance_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="3.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Height -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_height"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_height"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_height_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0.50"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Angle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_angle"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_angle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_angle_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="@string/vrm_angle_default_value"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ===== Display ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_display"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_render_scale"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_render_scale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_render_scale_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="1.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_target_fps"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/vrm_spinner_target_fps"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:spinnerMode="dropdown" />
                </LinearLayout>

                <!-- ===== Performance ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_performance"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vrm_label_fps_overlay"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/vrm_switch_fps_overlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC" />
                </LinearLayout>

                <TextView
                    android:id="@+id/vrm_text_fps_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#22000000"
                    android:padding="8dp"
                    android:text="@string/vrm_fps_info_empty"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp" />

                <!-- ===== Interaction ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_interaction"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vrm_label_touch_enabled"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/vrm_switch_touch_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/vrm_label_physbone_enabled"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/vrm_switch_physbone_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_log_level"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/vrm_spinner_log_level"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:spinnerMode="dropdown" />
                </LinearLayout>

                <!-- ===== Model transform ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_model_transform"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_model_offset_x"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_model_offset_x"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_model_offset_x_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_model_offset_y"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_model_offset_y"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_model_offset_y_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_model_offset_z"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_model_offset_z"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_model_offset_z_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_label_model_scale"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_model_scale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/vrm_text_model_scale_value"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="1.00"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/vrm_button_reset_model_transform"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="4dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text="@string/vrm_button_reset_model_transform"
                    android:textSize="12sp" />

                <!-- ===== Model info ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_model_info"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/vrm_text_model_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="#22000000"
                    android:padding="8dp"
                    android:text="@string/vrm_model_info_empty"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp" />

                <!-- ===== Profiles ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_profiles"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_profile_slot_1"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_save_profile_1"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_save"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_load_profile_1"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_load"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_profile_slot_2"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_save_profile_2"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_save"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_load_profile_2"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_load"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_profile_slot_3"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_save_profile_3"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_save"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/vrm_button_load_profile_3"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_load"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ===== Background ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_background"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/vrm_text_background_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/vrm_solid_background_mode"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/vrm_button_pick_image"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_pick_image"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/vrm_button_use_solid"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_use_solid"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Color preview + hex input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/vrm_view_color_preview"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:background="#333333" />

                    <EditText
                        android:id="@+id/vrm_edit_hex_color"
                        android:layout_width="90dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:background="#33FFFFFF"
                        android:gravity="center"
                        android:hint="#RRGGBB"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="7"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:singleLine="true"
                        android:text="#333333"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Red -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textColor="#FF6666"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_red"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- Green -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="G"
                        android:textColor="#66FF66"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_green"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- Blue -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="B"
                        android:textColor="#6666FF"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/vrm_seek_blue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- ===== Image Adjustment ===== -->
                <LinearLayout
                    android:id="@+id/vrm_panel_image_adjustment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/vrm_section_image_adjustment"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/vrm_label_fit_mode"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <Spinner
                            android:id="@+id/vrm_spinner_fit_mode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <!-- Offset X -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:text="@string/vrm_label_offset_x"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <SeekBar
                            android:id="@+id/vrm_seek_offset_x"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/vrm_text_offset_x_value"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="0.00"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Offset Y -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:text="@string/vrm_label_offset_y"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <SeekBar
                            android:id="@+id/vrm_seek_offset_y"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/vrm_text_offset_y_value"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="0.00"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Scale -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:text="@string/vrm_label_scale"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <SeekBar
                            android:id="@+id/vrm_seek_scale"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/vrm_text_scale_value"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="1.00"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/vrm_button_reset_adjustment"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="4dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_reset_adjustment"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ===== Actions ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/vrm_section_actions"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/vrm_button_set_wallpaper"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_set_wallpaper"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/vrm_button_reload_wallpaper"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/vrm_button_reload_wallpaper"
                        android:textSize="11sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/vrm_button_reset_all_settings"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text="@string/vrm_button_reset_all_settings"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
